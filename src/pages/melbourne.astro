---
// src/pages/melbourne.astro
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import BuyButton from '../components/BuyButton.astro';
import Endorsement from '../components/Endorsement.astro';
import AcknowledgmentOfCountry from '../components/AcknowledgmentOfCountry.astro';

import cover        from '../assets/book-images/melbourne-cover.jpg';
import spread01     from '../assets/book-images/melbourne-spread-01.jpg';
import spread13     from '../assets/book-images/melbourne-spread-13.jpg';
import spread31     from '../assets/book-images/melbourne-spread-31.jpg';
import bark         from '../assets/book-images/melliodora-bark.jpg';
import globBud      from '../assets/book-images/globoidea-bud.jpg';
import camFruit     from '../assets/book-images/camaldulensis-fruit.jpg';
import goniLeafJuv  from '../assets/book-images/goniocalyx-leaf-juv.jpg';
import goniBud      from '../assets/book-images/goniocalyx-bud.jpg';
import macrFruit    from '../assets/book-images/macrorhynca-fruit.jpg';

const allEndorsements = await getCollection('endorsements');
const featured = allEndorsements.filter(e => e.data.featured);

const stripeLink = 'https://buy.stripe.com/00w3cn2Wi7Yq7uf3pXgjC01';

const bookSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: 'ACE Guide to Eucalypts Melbourne',
  author: [
    { '@type': 'Person', name: 'Vicky Shukuroglou' },
    { '@type': 'Person', name: 'Roderick Fensham' },
  ],
  isbn: '9780645232615',
  publisher: { '@type': 'Organization', name: 'ACE Publishing' },
  description: "A field guide to Melbourne's 36 eucalypt species, identified by bark, fruit, bud, and leaf.",
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'AUD',
    price: '30',
    url: stripeLink,
  },
};
---

<Base
  title="ACE Guide to Eucalypts Melbourne — Field Guide to 36 Species"
  description="A field guide to Melbourne's 36 eucalypt species. Identified by bark, fruit, bud, and leaf, photographed in intimate detail by Vicky Shukuroglou and Rod Fensham."
  schemaJson={bookSchema}
  breadcrumbs={[{ name: 'Melbourne', href: '/melbourne/' }]}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner content-width">
      <div class="hero-cover">
        <Image
          src={cover}
          alt="Cover of the ACE Guide to Eucalypts Melbourne — eucalypt bark peeling in layers of grey, white, and rust"
          width={380}
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="hero-text">
        <p class="hero-eyebrow">ACE Guide to Eucalypts</p>
        <h1>Melbourne</h1>
        <p class="hero-subtitle">
          36 eucalypt species of greater Melbourne — identified by bark, fruit, bud,
          and leaf, photographed in intimate detail.
        </p>
        <div class="hero-meta">
          <span>Vicky Shukuroglou &amp; Rod Fensham</span>
          <span class="meta-sep">·</span>
          <span>Softcover, 56 pp</span>
          <span class="meta-sep">·</span>
          <span>$30 AUD + $7.50 postage &amp; handling</span>
        </div>
        <BuyButton text="Buy Now — $30 AUD" href={stripeLink} external={true} />
        <p class="hero-secure">Secure checkout via Stripe. No account needed.</p>
      </div>
    </div>
  </section>

  <!-- Book spreads: what the guide looks like inside -->
  <section class="section spreads" aria-label="Pages from the guide">
    <div class="wide-width">
      <h2 class="spreads-heading content-width">Every page is a work of art</h2>
      <p class="spreads-sub content-width">
        High-resolution photography of bark, leaves, buds, and fruit — laid out so you can
        make an identification in the field.
      </p>
      <div class="spreads-grid">
        <figure>
          <Image src={spread01} alt="Full page spread from the ACE Guide to Eucalypts Melbourne showing the book's visual layout" width={600} loading="lazy" />
        </figure>
        <figure>
          <Image src={spread13} alt="Interior spread from the ACE Guide showing species photography on a dark background" width={600} loading="lazy" />
        </figure>
        <figure>
          <Image src={spread31} alt="Interior spread from the ACE Guide showing bark, fruit, bud, and leaf identification details" width={600} loading="lazy" />
        </figure>
      </div>
    </div>
  </section>

  <!-- Species detail: each species, fully documented -->
  <section class="section species-pages" aria-label="Sample species details">
    <div class="wide-width">
      <h2 class="content-width">Each species, fully documented</h2>
      <p class="species-sub content-width">
        Bark, bud, fruit, and leaf — all the characteristics you need to confirm
        an identification, together on one page.
      </p>
      <div class="botany-grid">
        <figure>
          <Image src={bark} alt="Ribbony bark of Yellow Box (Eucalyptus melliodora) peeling in warm ochre and grey strips" width={500} loading="lazy" />
          <figcaption>Yellow Box bark <em>(E. melliodora)</em></figcaption>
        </figure>
        <figure>
          <Image src={camFruit} alt="Fruit capsules of River Red Gum (Eucalyptus camaldulensis) — small woody cups in a cluster" width={500} loading="lazy" />
          <figcaption>River Red Gum fruit <em>(E. camaldulensis)</em></figcaption>
        </figure>
        <figure>
          <Image src={goniBud} alt="Bud of Long-leafed Box (Eucalyptus goniocalyx) — a ribbed cap on a slender pedicel" width={500} loading="lazy" />
          <figcaption>Long-leafed Box bud <em>(E. goniocalyx)</em></figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Botanical photography grid -->
  <section class="section botany" aria-label="Botanical photography">
    <div class="wide-width">
      <h2 class="content-width">Photographed with care</h2>
      <p class="botany-sub content-width">
        Vicky Shukuroglou's original photography captures the textures and forms
        of Melbourne's eucalypts — bark you can almost feel, buds you could hold in
        your palm.
      </p>
      <div class="botany-grid">
        <figure>
          <Image src={globBud} alt="Clustered buds of White Stringybark (Eucalyptus globoidea) — pale green and intricate" width={500} loading="lazy" />
          <figcaption>White Stringybark buds <em>(E. globoidea)</em></figcaption>
        </figure>
        <figure class="leaf-crop">
          <Image src={goniLeafJuv} alt="Juvenile leaf of Long-leafed Box (Eucalyptus goniocalyx) — broad and softly veined" width={500} loading="lazy" />
          <figcaption>Juvenile leaf <em>(E. goniocalyx)</em></figcaption>
        </figure>
        <figure>
          <Image src={macrFruit} alt="Long woody fruit of Red Stringybark (Eucalyptus macrorhynca) — elongated and ribbed" width={500} loading="lazy" />
          <figcaption>Red Stringybark fruit <em>(E. macrorhynca)</em></figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section method">
    <div class="content-width">
      <h2>Identified by bark, fruit, bud, and leaf</h2>
      <p>
        The guide's identification method works with what you can see and touch in the
        field. Bark texture, fruit shape, bud form, and leaf character are combined
        to tell you which species you're looking at.
      </p>
      <p>
        Melbourne's species — 32 indigenous and 4 of the introduced — each have a
        profile page with life size photos. Accompanying maps and notes with details
        about distinguishing features, habitat, parks and reserves, help paint a
        clearer picture.
      </p>
    </div>
  </section>

  <!-- Endorsement -->
  {featured.length > 0 && (
    <section class="section" aria-label="Endorsements">
      <div class="content-width">
        <Endorsement
          quote={featured[0].data.quote}
          name={featured[0].data.name}
          credential={featured[0].data.credential}
        />
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="section final-cta">
    <div class="content-width">
      <h2>Get your copy</h2>
      <p>$30 AUD + $7.50 postage &amp; handling anywhere in Australia. Pocket-sized softcover, 56 pages.</p>
      <p class="cta-isbn">ISBN 9780645232615 — available to order through any bookshop.</p>
      <BuyButton text="Buy Now — $30 AUD" href={stripeLink} external={true} />
      <p class="cta-note">Secure checkout via Stripe. No account needed.</p>
    </div>
  </section>

  <AcknowledgmentOfCountry />

</Base>

<style>
  /* Hero */
  .hero {
    padding-block: var(--space-lg);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  @media (max-width: 700px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-cover {
      max-width: 240px;
      margin-inline: auto;
    }
  }

  .hero-cover img {
    width: 100%;
    border-radius: 0;
    box-shadow: 0 6px 32px rgba(44, 44, 42, 0.2);
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-olive);
    margin-bottom: var(--space-xs);
  }

  .hero h1 {
    margin-bottom: var(--space-xs);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .hero-meta {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0;
    align-items: center;
  }

  @media (max-width: 700px) {
    .hero-meta { justify-content: center; }
  }

  .meta-sep {
    margin-inline: 0.5rem;
    color: var(--color-olive);
  }

  .hero-secure {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  /* Spreads */
  .spreads {
    background-color: #1a1a18;
    padding-block: var(--space-lg);
  }

  .spreads-heading, .spreads-sub {
    color: var(--color-bg);
  }

  .spreads-sub {
    color: #b5afa9;
    font-size: 1.05rem;
    margin-bottom: var(--space-md);
  }

  .spreads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-sm);
  }

  .spreads-grid figure {
    margin: 0;
  }

  .spreads-grid img {
    width: 100%;
    border-radius: 0;
    display: block;
  }

  /* Species pages */
  .species-pages {
    padding-block: var(--space-lg);
  }

  .species-pages h2 {
    margin-bottom: var(--space-xs);
  }

  .species-sub {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin-bottom: var(--space-md);
  }

  /* Botanical photography */
  .botany {
    padding-block: var(--space-lg);
  }

  .botany h2 {
    margin-bottom: var(--space-xs);
  }

  .botany-sub {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin-bottom: var(--space-md);
  }

  .botany-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
  }

  @media (max-width: 860px) {
    .botany-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .botany-grid {
      grid-template-columns: 1fr;
    }
  }

  .botany-grid figure {
    margin: 0;
  }

  .botany-grid img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 0;
    display: block;
  }

  .leaf-crop img {
    object-position: right;
  }

  .botany-grid figcaption {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  /* Method */
  .method {
    background-color: #f0ebe4;
  }

  .method p + p {
    margin-top: var(--space-sm);
  }

  /* Final CTA */
  .final-cta {
    text-align: center;
    padding-block: var(--space-xl);
  }

  .final-cta h2 {
    margin-bottom: var(--space-sm);
  }

  .final-cta p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .cta-isbn {
    font-size: 0.85rem;
  }

  .cta-note {
    font-size: 0.8rem;
    margin-top: var(--space-xs);
  }
</style>
