---
// src/pages/buy.astro
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import BuyButton from '../components/BuyButton.astro';

import melbourneCover from '../assets/book-images/melbourne-cover.jpg';

const breadcrumbs = [{ name: 'Buy', href: '/buy/' }];

const melbourneStripeLink = 'https://buy.stripe.com/00w3cn2Wi7Yq7uf3pXgjC01';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: 'ACE Guide to Eucalypts Melbourne',
  author: [
    { '@type': 'Person', name: 'Vicky Shukuroglou' },
    { '@type': 'Person', name: 'Roderick Fensham' },
  ],
  isbn: '9780645232615',
  publisher: { '@type': 'Organization', name: 'ACE Publishing' },
  description: "A field guide to Melbourne's 36 eucalypt species, identified by bark, fruit, bud, and leaf.",
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'AUD',
    price: '30',
    url: melbourneStripeLink,
  },
};

---

<Base
  title="Buy the ACE Guide to Eucalypts Melbourne"
  description="Purchase the ACE Guide to Eucalypts Melbourne. $30 + $7.50 postage &amp; handling. Secure Stripe checkout."
  schemaJson={pageSchema}
  breadcrumbs={breadcrumbs}
>
  <section class="buy-page section">
    <div class="content-width">
      <h1 class="buy-heading">Buy the Guide</h1>

      <div class="editions-grid">

        <!-- Melbourne Edition -->
        <div class="edition-card">
          <div class="edition-cover">
            <a href={melbourneStripeLink} target="_blank" rel="noopener" aria-label="Buy Melbourne edition on Stripe">
              <Image
                src={melbourneCover}
                alt="Cover of the ACE Guide to Eucalypts Melbourne — eucalypt bark peeling in layers of grey, white, and rust"
                width={360}
                loading="eager"
              />
            </a>
          </div>
          <div class="edition-details">
            <h2>Melbourne</h2>
            <p class="edition-subtitle">36 eucalypt species of greater Melbourne</p>

            <dl class="book-facts">
              <dt>Authors</dt>
              <dd>Vicky Shukuroglou &amp; Roderick Fensham</dd>

              <dt>Publisher</dt>
              <dd>ACE Publishing</dd>

              <dt>ISBN</dt>
              <dd>9780645232615</dd>

              <dt>Price</dt>
              <dd>$30 AUD + $7.50 postage &amp; handling (Australia)</dd>

              <dt>Format</dt>
              <dd>Softcover pocket guide</dd>
            </dl>

            <div class="buy-primary">
              <BuyButton
                text="Buy Now — $30 AUD"
                href={melbourneStripeLink}
                external={true}
              />
              <p class="buy-secure">Secure checkout via Stripe. No account needed.</p>
            </div>
          </div>
        </div>

      </div><!-- /.editions-grid -->

      <!-- Info below the edition card -->
      <div class="buy-shared">
        <p class="buy-indie">
          Or ask your local bookshop — they can order it by ISBN.
        </p>

        <p class="buy-contact">
          Wholesale or bulk orders? Email <a href="mailto:info@eucalyptsmelbourne.au">info@eucalyptsmelbourne.au</a>.
        </p>

        <p class="buy-gift">
          Know someone who walks in the bush? It makes a meaningful gift.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .buy-heading {
    margin-bottom: var(--space-md);
  }

  .editions-grid {
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-lg);
  }

  .edition-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .edition-cover a {
    display: block;
  }

  .edition-cover img {
    width: 100%;
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(44, 44, 42, 0.1);
    transition: transform 150ms ease, box-shadow 150ms ease;
  }

  .edition-cover a:hover img {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(44, 44, 42, 0.18);
  }

  .edition-details h2 {
    margin-bottom: var(--space-xs);
  }

  .edition-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .book-facts {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xs) var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .book-facts dt {
    font-weight: 600;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .buy-primary {
    margin-bottom: var(--space-md);
  }

  .buy-secure {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .buy-shared {
    border-top: 1px solid var(--color-text-secondary);
    padding-top: var(--space-md);
  }

  .buy-indie {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .buy-contact {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .buy-gift {
    margin-top: var(--space-sm);
    font-style: italic;
    color: var(--color-text-secondary);
  }
</style>
