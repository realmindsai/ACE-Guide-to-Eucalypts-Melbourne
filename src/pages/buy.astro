---
// src/pages/buy.astro
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import BuyButton from '../components/BuyButton.astro';

import melbourneCover from '../assets/book-images/melbourne-cover.jpg';
import brisbaneCover from '../assets/book-images/brisbane-cover.jpg';

const breadcrumbs = [{ name: 'Buy', href: '/buy/' }];

const melbourneStripeLink = 'https://buy.stripe.com/00w3cn2Wi7Yq7uf3pXgjC01';
const brisbaneStripeLink  = 'https://buy.stripe.com/4gM6ozcwSguW5m78KhgjC02';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: {
        '@type': 'Book',
        name: 'ACE Guide to Eucalypts Melbourne',
        author: [
          { '@type': 'Person', name: 'Vicky Shukuroglou' },
          { '@type': 'Person', name: 'Roderick Fensham' },
        ],
        isbn: '9780645232615',
        publisher: { '@type': 'Organization', name: 'ACE Publishing' },
        description: "A field guide to Melbourne's 36 eucalypt species, identified through bark texture and fruit characteristics.",
        offers: {
          '@type': 'Offer',
          availability: 'https://schema.org/InStock',
          priceCurrency: 'AUD',
          price: '30',
          url: melbourneStripeLink,
        },
      },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: {
        '@type': 'Book',
        name: 'ACE Guide to Eucalypts Brisbane',
        author: [
          { '@type': 'Person', name: 'Roderick Fensham' },
        ],
        isbn: '9780645232608',
        publisher: { '@type': 'Organization', name: 'ACE Publishing' },
        description: "A field guide to Brisbane's 37 eucalypt species, identified through bark texture and fruit characteristics.",
        offers: {
          '@type': 'Offer',
          availability: 'https://schema.org/InStock',
          priceCurrency: 'AUD',
          price: '30',
          url: brisbaneStripeLink,
        },
      },
    },
  ],
};

const otherRetailers = [
  { name: 'Australian Koala Foundation', href: 'https://savethekoala.com/shop/products/book-ace-guide-to-eucalypts/' },
  { name: 'Booktopia', href: '#' },
  { name: 'Dymocks', href: '#' },
];
---

<Base
  title="Buy the ACE Guide to Eucalypts — Melbourne &amp; Brisbane"
  description="Purchase the ACE Guide to Eucalypts — Melbourne or Brisbane edition. $30 + postage. Secure Stripe checkout."
  schemaJson={pageSchema}
  breadcrumbs={breadcrumbs}
>
  <section class="buy-page section">
    <div class="content-width">
      <h1 class="buy-heading">Choose your edition</h1>

      <div class="editions-grid">

        <!-- Melbourne Edition -->
        <div class="edition-card">
          <div class="edition-cover">
            <a href={melbourneStripeLink} target="_blank" rel="noopener" aria-label="Buy Melbourne edition on Stripe">
              <Image
                src={melbourneCover}
                alt="Cover of the ACE Guide to Eucalypts Melbourne — eucalypt bark peeling in layers of grey, white, and rust"
                width={360}
                loading="eager"
              />
            </a>
          </div>
          <div class="edition-details">
            <h2>Melbourne</h2>
            <p class="edition-subtitle">36 eucalypt species of greater Melbourne</p>

            <dl class="book-facts">
              <dt>Authors</dt>
              <dd>Vicky Shukuroglou &amp; Roderick Fensham</dd>

              <dt>Publisher</dt>
              <dd>ACE Publishing</dd>

              <dt>ISBN</dt>
              <dd>9780645232615</dd>

              <dt>Price</dt>
              <dd>$30 AUD + $6 postage (Australia)</dd>

              <dt>Format</dt>
              <dd>Softcover pocket guide</dd>
            </dl>

            <div class="buy-primary">
              <BuyButton
                text="Buy Now — $36 AUD (inc. postage)"
                href={melbourneStripeLink}
                external={true}
              />
              <p class="buy-secure">Secure checkout via Stripe. No account needed.</p>
            </div>
          </div>
        </div>

        <!-- Brisbane Edition -->
        <div class="edition-card">
          <div class="edition-cover">
            <a href={brisbaneStripeLink} target="_blank" rel="noopener" aria-label="Buy Brisbane edition on Stripe">
              <Image
                src={brisbaneCover}
                alt="Cover of the ACE Guide to Eucalypts Brisbane"
                width={360}
                loading="eager"
              />
            </a>
          </div>
          <div class="edition-details">
            <h2>Brisbane</h2>
            <p class="edition-subtitle">37 eucalypt species of greater Brisbane</p>

            <dl class="book-facts">
              <dt>Author</dt>
              <dd>Roderick Fensham</dd>

              <dt>Publisher</dt>
              <dd>ACE Publishing</dd>

              <dt>ISBN</dt>
              <dd>9780645232608</dd>

              <dt>Price</dt>
              <dd>$30 AUD + $6 postage (Australia)</dd>

              <dt>Format</dt>
              <dd>Softcover pocket guide</dd>
            </dl>

            <div class="buy-primary">
              <BuyButton
                text="Buy Now — $36 AUD (inc. postage)"
                href={brisbaneStripeLink}
                external={true}
              />
              <p class="buy-secure">Secure checkout via Stripe. No account needed.</p>
            </div>
          </div>
        </div>

      </div><!-- /.editions-grid -->

      <!-- Shared info below both cards -->
      <div class="buy-shared">
        <div class="buy-secondary">
          <h2>Also available from</h2>
          <div class="retailer-buttons">
            {otherRetailers.map(r => (
              <BuyButton
                text={r.name}
                href={r.href}
                external={true}
              />
            ))}
          </div>
        </div>

        <p class="buy-indie">
          Or ask your local bookshop — they can order either edition by ISBN.
        </p>

        <p class="buy-contact">
          Wholesale or bulk orders? Email <a href="mailto:aceguidetoeucalypts@gmail.com">aceguidetoeucalypts@gmail.com</a>.
        </p>

        <p class="buy-gift">
          Know someone who walks in the bush? These make a meaningful gift.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .buy-heading {
    margin-bottom: var(--space-md);
  }

  .editions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: start;
    margin-bottom: var(--space-lg);
  }

  @media (max-width: 860px) {
    .editions-grid {
      grid-template-columns: 1fr;
    }
  }

  .edition-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .edition-cover a {
    display: block;
  }

  .edition-cover img {
    width: 100%;
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(44, 44, 42, 0.1);
    transition: transform 150ms ease, box-shadow 150ms ease;
  }

  .edition-cover a:hover img {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(44, 44, 42, 0.18);
  }

  .edition-details h2 {
    margin-bottom: var(--space-xs);
  }

  .edition-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .book-facts {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xs) var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .book-facts dt {
    font-weight: 600;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .buy-primary {
    margin-bottom: var(--space-md);
  }

  .buy-secure {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .buy-shared {
    border-top: 1px solid var(--color-text-secondary);
    padding-top: var(--space-md);
  }

  .buy-secondary {
    margin-bottom: var(--space-md);
  }

  .buy-secondary h2 {
    font-size: 1rem;
    margin-bottom: var(--space-xs);
    color: var(--color-text-secondary);
  }

  .retailer-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .retailer-buttons :global(.buy-button) {
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    background-color: var(--color-text-secondary);
  }

  .retailer-buttons :global(.buy-button:hover) {
    background-color: var(--color-text);
  }

  .buy-indie {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .buy-contact {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .buy-gift {
    margin-top: var(--space-sm);
    font-style: italic;
    color: var(--color-text-secondary);
  }
</style>
