---
// src/pages/brisbane.astro
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import BuyButton from '../components/BuyButton.astro';
import AcknowledgmentOfCountry from '../components/AcknowledgmentOfCountry.astro';

import cover     from '../assets/book-images/brisbane-cover.jpg';
import camFruit  from '../assets/book-images/camaldulensis-fruit.jpg';

const stripeLink = 'https://buy.stripe.com/4gM6ozcwSguW5m78KhgjC02';

const bookSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: 'ACE Guide to Eucalypts Brisbane',
  author: [
    { '@type': 'Person', name: 'Roderick Fensham' },
  ],
  isbn: '9780645232608',
  publisher: { '@type': 'Organization', name: 'Keeaira Press' },
  description: "A field guide to Brisbane's 37 eucalypt species, identified through bark texture and fruit characteristics.",
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'AUD',
    price: '30',
    url: stripeLink,
  },
};
---

<Base
  title="ACE Guide to Eucalypts Brisbane — Field Guide to 37 Species"
  description="A field guide to Brisbane's 37 eucalypt species. Identified by bark and fruit, with photography and habitat notes. By Roderick Fensham."
  schemaJson={bookSchema}
  breadcrumbs={[{ name: 'Brisbane', href: '/brisbane/' }]}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner content-width">
      <div class="hero-cover">
        <Image
          src={cover}
          alt="Cover of the ACE Guide to Eucalypts Brisbane"
          width={380}
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="hero-text">
        <p class="hero-eyebrow">ACE Guide to Eucalypts</p>
        <h1>Brisbane</h1>
        <p class="hero-subtitle">
          37 eucalypt species of greater Brisbane — identified through bark
          and fruit, with habitat notes and a guide to where each species
          grows in Brisbane's bushland reserves.
        </p>
        <div class="hero-meta">
          <span>Roderick Fensham</span>
          <span class="meta-sep">·</span>
          <span>Softcover, 48 pp</span>
          <span class="meta-sep">·</span>
          <span>$36 AUD inc. postage</span>
        </div>
        <BuyButton text="Buy Now — $36 AUD" href={stripeLink} external={true} />
        <p class="hero-secure">Secure checkout via Stripe. No account needed.</p>
      </div>
    </div>
  </section>

  <!-- About the guide -->
  <section class="section about-guide">
    <div class="content-width about-grid">
      <div class="about-text">
        <h2>About the guide</h2>
        <p>
          Brisbane's bushland reserves are home to 36 local eucalypt species and one
          naturalised species — the Cadaghi (<em>Corymbia torelliana</em>) — making it
          one of the most eucalypt-diverse urban landscapes in Australia.
        </p>
        <p>
          Professor Rod Fensham, ecologist at the University of Queensland and the
          Queensland Herbarium, developed the ACE identification method — using bark
          texture and fruit shape to name a species without needing to wait for
          flowering. This guide puts that method in your pocket.
        </p>
        <p>
          A map and quick-reference species list help you find particular eucalypts
          in Brisbane's parks. Aboriginal knowledge and names in local language
          are included throughout.
        </p>

        <dl class="book-facts">
          <dt>Author</dt>
          <dd>Roderick Fensham</dd>

          <dt>Publisher</dt>
          <dd>Keeaira Press</dd>

          <dt>ISBN</dt>
          <dd>9780645232608</dd>

          <dt>Published</dt>
          <dd>August 2021</dd>

          <dt>Species</dt>
          <dd>37 (36 local + 1 naturalised)</dd>

          <dt>Format</dt>
          <dd>Softcover pocket guide, 48 pp</dd>
        </dl>
      </div>

      <div class="about-photo">
        <figure>
          <Image
            src={camFruit}
            alt="Fruit capsules of River Red Gum (Eucalyptus camaldulensis) — small woody cups clustered on a stem, found across Brisbane's reserves"
            width={520}
            loading="lazy"
          />
          <figcaption>
            River Red Gum fruit <em>(E. camaldulensis)</em> — one of Brisbane's
            most recognisable eucalypts
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Method -->
  <section class="section method">
    <div class="content-width">
      <h2>Identified by bark and fruit</h2>
      <p>
        The ACE method works in the field, any time of year. Bark texture is constant —
        stringybark sheds in long strips, boxes hold their bark firmly, gums shed to
        smooth white or cream. Fruit shape confirms the identification.
      </p>
      <p>
        You don't need to be a botanist. You just need the guide in your hand and
        a tree in front of you.
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section final-cta">
    <div class="content-width">
      <h2>Get your copy</h2>
      <p>$30 AUD + $6 postage anywhere in Australia. Pocket-sized, 48 pages.</p>
      <p class="cta-isbn">ISBN 9780645232608 — available to order through any bookshop.</p>
      <BuyButton text="Buy Now — $36 AUD (inc. postage)" href={stripeLink} external={true} />
      <p class="cta-note">Secure checkout via Stripe. No account needed.</p>
    </div>
  </section>

  <AcknowledgmentOfCountry />

</Base>

<style>
  /* Hero */
  .hero {
    padding-block: var(--space-lg);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  @media (max-width: 700px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-cover {
      max-width: 240px;
      margin-inline: auto;
    }
  }

  .hero-cover img {
    width: 100%;
    border-radius: 4px;
    box-shadow: 0 6px 32px rgba(44, 44, 42, 0.2);
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-olive);
    margin-bottom: var(--space-xs);
  }

  .hero h1 {
    margin-bottom: var(--space-xs);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .hero-meta {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0;
    align-items: center;
  }

  @media (max-width: 700px) {
    .hero-meta { justify-content: center; }
  }

  .meta-sep {
    margin-inline: 0.5rem;
    color: var(--color-olive);
  }

  .hero-secure {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  /* About section */
  .about-guide {
    background-color: #f0ebe4;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  @media (max-width: 760px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  .about-text h2 {
    margin-bottom: var(--space-sm);
  }

  .about-text p + p {
    margin-top: var(--space-sm);
  }

  .book-facts {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xs) var(--space-sm);
    margin-top: var(--space-md);
  }

  .book-facts dt {
    font-weight: 600;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .about-photo figure {
    margin: 0;
  }

  .about-photo img {
    width: 100%;
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(44, 44, 42, 0.1);
  }

  .about-photo figcaption {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  /* Method */
  .method p + p {
    margin-top: var(--space-sm);
  }

  /* Final CTA */
  .final-cta {
    text-align: center;
    padding-block: var(--space-xl);
    background-color: #f0ebe4;
  }

  .final-cta h2 {
    margin-bottom: var(--space-sm);
  }

  .final-cta p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .cta-isbn {
    font-size: 0.85rem;
  }

  .cta-note {
    font-size: 0.8rem;
    margin-top: var(--space-xs);
  }
</style>
