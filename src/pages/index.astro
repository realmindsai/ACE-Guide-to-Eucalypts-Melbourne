---
// src/pages/index.astro
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Endorsement from '../components/Endorsement.astro';
import AuthorCard from '../components/AuthorCard.astro';
import AcknowledgmentOfCountry from '../components/AcknowledgmentOfCountry.astro';
import BuyButton from '../components/BuyButton.astro';

import melbourneCover from '../assets/book-images/melbourne-cover.jpg';
import baxteri from '../assets/book-images/baxteri-page.jpg';
import shiningGum from '../assets/book-images/interior-shining-gum.jpg';
import plunkettMallee from '../assets/book-images/interior-plunkett-mallee.jpg';

const allEndorsements = await getCollection('endorsements');
const featuredEndorsements = allEndorsements.filter(e => e.data.featured);

const bookSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: 'ACE Guide to Eucalypts Melbourne',
  author: [
    { '@type': 'Person', name: 'Vicky Shukuroglou' },
    { '@type': 'Person', name: 'Roderick Fensham' },
  ],
  isbn: '9780645232615',
  publisher: { '@type': 'Organization', name: 'ACE Publishing' },
  description: 'A field guide to Melbourne\'s 36 eucalypt species, identified through bark texture and fruit characteristics.',
};
---

<Base
  title="ACE Guide to Eucalypts Melbourne — A Field Guide to Melbourne's Eucalypts"
  description="A field guide to Melbourne's 36 eucalypt species. Identified through bark and fruit, photographed in intimate detail. By Vicky Shukuroglou and Rod Fensham."
  schemaJson={bookSchema}
>
  <!-- Hero: Book cover -->
  <section class="hero">
    <div class="hero-inner content-width">
      <div class="hero-cover">
        <Image src={melbourneCover} alt="Cover of the ACE Guide to Eucalypts Melbourne — eucalypt bark peeling in layers of grey, white, and rust" width={400} loading="eager" fetchpriority="high" />
      </div>
      <div class="hero-text">
        <h1>ACE Guide to Eucalypts Melbourne</h1>
        <p class="hero-subtitle">A field guide to Melbourne's 36 eucalypt species, identified through bark and fruit, photographed in intimate detail.</p>
        <BuyButton text="Get the Book" />
      </div>
    </div>
  </section>

  <!-- Interior showcase: pages from the guide -->
  <section class="section showcase" aria-label="Pages from the guide">
    <div class="wide-width">
      <h2 class="content-width">Every page is a work of art</h2>
      <div class="showcase-grid">
        <figure>
          <Image src={baxteri} alt="Species page for Brown Stringybark (Eucalyptus baxteri) showing leaves, buds, fruit, and bark detail on a dark background" width={400} loading="lazy" />
          <figcaption>Brown Stringybark (<em>E. baxteri</em>)</figcaption>
        </figure>
        <figure>
          <Image src={shiningGum} alt="Species page for Shining Gum (Eucalyptus nitens) showing leaves, buds, and bark on a dark background" width={400} loading="lazy" />
          <figcaption>Shining Gum (<em>E. nitens</em>)</figcaption>
        </figure>
        <figure>
          <Image src={plunkettMallee} alt="Species page for Plunkett Mallee (Eucalyptus curtisii) showing leaves, buds, fruit, and bark on a dark background" width={400} loading="lazy" />
          <figcaption>Plunkett Mallee (<em>E. curtisii</em>)</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Endorsement -->
  {featuredEndorsements.length > 0 && (
    <section class="section" aria-label="Endorsements">
      <div class="content-width">
        {featuredEndorsements.slice(0, 1).map(e => (
          <Endorsement
            quote={e.data.quote}
            name={e.data.name}
            credential={e.data.credential}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Authors -->
  <section class="section" aria-label="Authors">
    <div class="content-width">
      <h2>The Authors</h2>
      <div class="author-grid">
        <AuthorCard
          name="Vicky Shukuroglou"
          role="Author, photographer, artist"
          imageSrc="/images/authors/vicky-placeholder.svg"
          imageAlt="Portrait of Vicky Shukuroglou"
          href="/authors/"
        />
        <AuthorCard
          name="Rod Fensham"
          role="Ecologist, University of Queensland"
          imageSrc="/images/authors/rod-placeholder.svg"
          imageAlt="Portrait of Rod Fensham"
          href="/authors/"
        />
      </div>
    </div>
  </section>

  <!-- Acknowledgment of Country -->
  <AcknowledgmentOfCountry />
</Base>

<style>
  .hero {
    padding-block: var(--space-lg);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  @media (max-width: 640px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-cover {
      max-width: 240px;
      margin-inline: auto;
    }
  }

  .hero-cover img {
    width: 100%;
    border-radius: 4px;
    box-shadow: 0 4px 24px rgba(44, 44, 42, 0.15);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-block: var(--space-sm);
  }

  .showcase {
    background-color: #1a1a18;
    padding-block: var(--space-lg);
  }

  .showcase h2 {
    color: var(--color-bg);
    margin-bottom: var(--space-md);
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .showcase figure {
    margin: 0;
  }

  .showcase figure img {
    width: 100%;
    border-radius: 4px;
  }

  .showcase figcaption {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    margin-top: var(--space-xs);
  }

  .author-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }
</style>
