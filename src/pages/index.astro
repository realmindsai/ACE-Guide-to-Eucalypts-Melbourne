---
// src/pages/index.astro
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Endorsement from '../components/Endorsement.astro';
import AcknowledgmentOfCountry from '../components/AcknowledgmentOfCountry.astro';
import BuyButton from '../components/BuyButton.astro';
import { url } from '../utils/url';

import melbourneCover from '../assets/book-images/melbourne-cover.jpg';
import brisbaneCover  from '../assets/book-images/brisbane-cover.jpg';

const allEndorsements = await getCollection('endorsements');
const featured = allEndorsements.filter(e => e.data.featured);

const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ACE Guide to Eucalypts',
  url: 'https://realmindsai.github.io/ACE-Guide-to-Eucalypts-Melbourne/',
  description: 'Pocket field guides to eucalypt species in Melbourne and Brisbane — identified by bark, fruit, bud, and leaf.',
};
---

<Base
  title="ACE Guide to Eucalypts — Melbourne &amp; Brisbane"
  description="Pocket field guides to Melbourne and Brisbane's eucalypt species. Identified by bark, fruit, bud, and leaf, photographed in intimate detail."
  schemaJson={siteSchema}
>

  <!-- Hero: both books side by side -->
  <section class="hero">
    <div class="hero-inner wide-width">
      <div class="hero-text">
        <p class="hero-eyebrow">ACE Guide to Eucalypts</p>
        <h1>Know the trees<br/>around you</h1>
        <p class="hero-subtitle">
          Pocket field guides to Melbourne and Brisbane's eucalypt species —
          identified by bark, fruit, bud, and leaf, photographed in intimate detail.
        </p>
      </div>

      <div class="books-spread">
        <a href={url('/melbourne/')} class="book-card">
          <Image
            src={melbourneCover}
            alt="ACE Guide to Eucalypts Melbourne — softcover field guide"
            width={320}
            loading="eager"
            fetchpriority="high"
          />
          <div class="book-label">
            <span class="book-city">Melbourne</span>
            <span class="book-species">36 species</span>
          </div>
        </a>

        <a href={url('/brisbane/')} class="book-card">
          <Image
            src={brisbaneCover}
            alt="ACE Guide to Eucalypts Brisbane — softcover field guide"
            width={320}
            loading="eager"
            fetchpriority="high"
          />
          <div class="book-label">
            <span class="book-city">Brisbane</span>
            <span class="book-species">37 species</span>
          </div>
        </a>
      </div>

      <div class="hero-cta">
        <BuyButton text="Buy Melbourne — $30 AUD" href="https://buy.stripe.com/00w3cn2Wi7Yq7uf3pXgjC01" external={true} />
        <BuyButton text="Buy Brisbane — $30 AUD" href="https://buy.stripe.com/4gM6ozcwSguW5m78KhgjC02" external={true} />
        <p class="hero-secure">Secure checkout via Stripe. No account needed.</p>
      </div>
    </div>
  </section>

  <!-- Endorsements -->
  {featured.length > 0 && (
    <section class="section" aria-label="Endorsements">
      <div class="content-width">
        {featured.slice(0, 2).map(e => (
          <Endorsement
            quote={e.data.quote}
            name={e.data.name}
            credential={e.data.credential}
          />
        ))}
      </div>
    </section>
  )}

  <!-- What the ACE method is -->
  <section class="section method">
    <div class="content-width">
      <h2>Identified by bark, fruit, bud, and leaf</h2>
      <p>
        The ACE method works year-round, using bark texture, fruit shape, bud form,
        and leaf character — characteristics that are always there, always touchable.
      </p>
      <p>
        No botanical training required. Each guide walks you through the method
        step by step, with photography precise enough to compare against what's
        in front of you.
      </p>
      <div class="method-links">
        <a href={url('/melbourne/')}>See the Melbourne guide →</a>
        <a href={url('/brisbane/')}>See the Brisbane guide →</a>
      </div>
    </div>
  </section>

  <AcknowledgmentOfCountry />

</Base>

<style>
  /* Hero */
  .hero {
    padding-block: var(--space-lg);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: center;
    text-align: center;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-olive);
    margin-bottom: var(--space-xs);
  }

  .hero-text h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.15;
    margin-bottom: var(--space-sm);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 52ch;
    margin-inline: auto;
  }

  /* Books spread */
  .books-spread {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    max-width: 680px;
    margin-inline: auto;
  }

  @media (max-width: 480px) {
    .books-spread {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-sm);
    }
  }

  .book-card {
    display: block;
    text-decoration: none;
    transition: transform 150ms ease;
  }

  .book-card:hover {
    transform: translateY(-4px);
  }

  .book-card img {
    width: 100%;
    border-radius: 4px;
    box-shadow: 0 6px 28px rgba(44, 44, 42, 0.18);
    display: block;
  }

  .book-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: var(--space-xs);
    padding-inline: 0.1rem;
  }

  .book-city {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .book-species {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  /* CTA row */
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: center;
    justify-content: center;
  }

  .hero-secure {
    width: 100%;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Method section */
  .method {
    background-color: #f0ebe4;
  }

  .method p + p {
    margin-top: var(--space-sm);
  }

  .method-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .method-links a {
    color: var(--color-cta);
    font-weight: 600;
    text-decoration: none;
  }

  .method-links a:hover {
    text-decoration: underline;
  }
</style>
