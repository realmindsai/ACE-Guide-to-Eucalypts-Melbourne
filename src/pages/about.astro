---
// src/pages/about.astro
import Page from '../layouts/Page.astro';
import BuyButton from '../components/BuyButton.astro';

const breadcrumbs = [{ name: 'About', href: '/about/' }];
---

<Page
  title="About the ACE Guide to Eucalypts Melbourne"
  description="A field guide to Melbourne's 36 eucalypt species. Bark texture, fruit characteristics, and intimate photography help you identify the eucalypts around you."
  breadcrumbs={breadcrumbs}
>
  <h1>About the Guide</h1>

  <!-- PLACEHOLDER: Replace with final copy -->
  <p>
    The ACE Guide to Eucalypts Melbourne covers 36 eucalypt species found across
    the greater Melbourne region — 32 indigenous and 4 introduced. Each species
    entry includes high-resolution photography of bark, leaves, buds, and fruit,
    along with identification notes, habitat information, and where to find each
    species in Melbourne's parks and reserves.
  </p>

  <p>
    The guide walks you through identification using bark texture and fruit
    characteristics — a practical method that works in the field with what you
    can see and touch.
  </p>

  <h2>Who It's For</h2>
  <p>
    Bushwalkers who want to know the trees they're walking among. Gardeners
    choosing indigenous species for their yard. Field naturalists. Anyone who
    wants to give a beautiful, meaningful gift to someone who loves Melbourne's
    bushland.
  </p>

  <h2>The Dahl Fellowship</h2>
  <!-- PLACEHOLDER: Replace with real Eucalypt Australia story -->
  <p>
    This guide was made possible through a Dahl Fellowship from
    <a href="https://eucalyptaustralia.org.au/" target="_blank" rel="noopener">Eucalypt Australia</a>,
    supporting research and education about Australia's iconic eucalypt heritage.
  </p>

  <div class="about-cta">
    <BuyButton text="Get the Guide" />
  </div>
</Page>

<style>
  h2 {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .about-cta {
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-olive);
  }
</style>
